---
const navItems = [
  { href: '/', label: 'Início' },
  { href: '/#lugares', label: 'Lugares' },
];
---

<header class="sticky top-0 z-50 border-b border-ipiranga-warm/80 bg-ipiranga-cream/95 backdrop-blur-sm">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
    <a href="/" class="font-display text-xl font-semibold text-ipiranga-green sm:text-2xl">
      Ipiranga Pocket List
    </a>
    <nav aria-label="Principal">
      <ul class="flex gap-6">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm font-medium text-ipiranga-muted transition-colors hover:text-ipiranga-green focus:outline-none focus:ring-2 focus:ring-ipiranga-amber focus:ring-offset-2 rounded"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
