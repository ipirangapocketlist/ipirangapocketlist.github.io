---
const year = new Date().getFullYear();
---

<footer class="border-t border-swiss-black bg-swiss-black text-swiss-white">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-12 sm:grid-cols-3 sm:px-8">
    <div>
      <p class="text-lg font-bold tracking-tight">IPIRANGA</p>
      <p class="mt-1 text-xs uppercase tracking-[0.2em] text-swiss-gray-400">Pocket List</p>
    </div>
    <div class="flex flex-col gap-2 text-xs uppercase tracking-widest">
      <a href="/#lugares" class="text-swiss-gray-400 transition-colors hover:text-swiss-white">Lugares</a>
      <a href="/#vizinhos" class="text-swiss-gray-400 transition-colors hover:text-swiss-white">Vizinhos</a>
      <a href="/#historia" class="text-swiss-gray-400 transition-colors hover:text-swiss-white">História</a>
    </div>
    <div class="text-right text-xs text-swiss-gray-400">
      <p>Guia curado do bairro</p>
      <p class="mt-1">{year}</p>
    </div>
  </div>
</footer>
