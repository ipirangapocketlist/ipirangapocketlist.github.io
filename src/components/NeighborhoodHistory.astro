---
import { historiaIpiranga } from '../data/historia-ipiranga';
---

<section class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16" aria-labelledby="historia-titulo">
  <h2 id="historia-titulo" class="font-display mb-8 text-3xl font-semibold text-ipiranga-green sm:text-4xl">
    {historiaIpiranga.titulo}
  </h2>
  <div class="space-y-5 text-lg leading-relaxed text-ipiranga-text">
    {
      historiaIpiranga.paragrafos.map((paragrafo) => (
        <p>{paragrafo}</p>
      ))
    }
  </div>
</section>
