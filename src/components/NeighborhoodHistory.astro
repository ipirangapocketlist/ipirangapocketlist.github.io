---
import { historiaIpiranga } from '../data/historia-ipiranga';
import HistoryCarousel from './HistoryCarousel';
---

<section
  id="historia"
  class="border-b border-swiss-black bg-swiss-gray-100 px-4 py-12 sm:px-6 sm:py-20 md:px-8 md:py-24"
  aria-labelledby="historia-titulo"
>
  <div class="mx-auto grid max-w-7xl gap-8 sm:gap-12 lg:grid-cols-12 lg:gap-16">
    <div class="min-w-0 lg:col-span-4">
      <span class="swiss-label">02 — História</span>
      <h2
        id="historia-titulo"
        class="mt-4 text-[clamp(1.75rem,5vw,3rem)] font-bold leading-tight tracking-tight break-words"
      >
        {historiaIpiranga.titulo}
      </h2>
      <div class="swiss-rule-red mt-6"></div>
      <p class="mt-6 text-[clamp(0.8125rem,2.5vw,0.875rem)] leading-relaxed text-swiss-gray-600">
        Deslize ou aguarde — carrossel editorial com a história do bairro.
      </p>
    </div>
    <div class="min-w-0 lg:col-span-8">
      <HistoryCarousel client:visible paragraphs={historiaIpiranga.paragrafos} />
    </div>
  </div>
</section>
