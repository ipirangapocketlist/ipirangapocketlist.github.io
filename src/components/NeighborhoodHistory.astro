---
import { historiaIpiranga } from '../data/historia-ipiranga';
import HistoryCarousel from './HistoryCarousel';
---

<section
  id="historia"
  class="border-b border-swiss-black bg-swiss-gray-100 px-4 py-16 sm:px-8 sm:py-24"
  aria-labelledby="historia-titulo"
>
  <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-12 lg:gap-16">
    <div class="lg:col-span-4">
      <span class="swiss-label">02 — História</span>
      <h2
        id="historia-titulo"
        class="mt-4 text-3xl font-bold leading-none tracking-tight sm:text-4xl lg:text-5xl"
      >
        {historiaIpiranga.titulo}
      </h2>
      <div class="swiss-rule-red mt-6"></div>
      <p class="mt-6 text-sm leading-relaxed text-swiss-gray-600">
        Deslize ou aguarde — carrossel editorial com a história do bairro.
      </p>
    </div>
    <div class="lg:col-span-8">
      <HistoryCarousel client:visible paragraphs={historiaIpiranga.paragrafos} />
    </div>
  </div>
</section>
