---
import { getAllVizinhosBairros } from '../lib/vizinhos';
import VizinhosCarousel from './VizinhosCarousel';

const bairros = getAllVizinhosBairros();
---

<section id="vizinhos" class="border-t border-swiss-black px-4 py-12 sm:px-6 sm:py-20 md:px-8 md:py-24">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-8 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <span class="swiss-label">04 — Vizinhos</span>
        <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
          Conhecendo os vizinhos
        </h2>
        <div class="swiss-rule-red mt-6"></div>
      </div>
      <div class="lg:col-span-8">
        {
          bairros.map((bairro) => (
            <div>
              <h3 class="text-xl font-bold uppercase tracking-tight">{bairro.bairro}</h3>
              <p class="mt-3 max-w-xl text-sm leading-relaxed text-swiss-gray-600">
                {bairro.introducao}
              </p>
              <div class="mt-10">
                <VizinhosCarousel client:visible bairro={bairro} />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
