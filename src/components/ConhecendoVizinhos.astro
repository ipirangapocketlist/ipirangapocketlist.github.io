---
import { getAllVizinhosBairros } from '../lib/vizinhos';
import VizinhosCarousel from './VizinhosCarousel';

const bairros = getAllVizinhosBairros();
---

<section id="vizinhos" class="border-t border-swiss-black px-4 py-12 sm:px-6 sm:py-20 md:px-8 md:py-24">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-8 lg:grid-cols-12">
      <div class="min-w-0 lg:col-span-4">
        <span class="swiss-label">04 — Vizinhos</span>
        <h2 class="mt-4 text-[clamp(1.75rem,5vw,3rem)] font-bold leading-tight tracking-tight break-words">
          Conhecendo os vizinhos
        </h2>
        <div class="swiss-rule-red mt-6"></div>
      </div>
      <div class="min-w-0 lg:col-span-8">
        {
          bairros.map((bairro) => (
            <div class="min-w-0">
              <h3 class="text-[clamp(1.125rem,3.5vw,1.25rem)] font-bold uppercase tracking-tight break-words">{bairro.bairro}</h3>
              <p class="mt-3 w-full text-[clamp(0.8125rem,2.5vw,0.875rem)] leading-relaxed text-swiss-gray-600 break-words hyphens-auto lg:max-w-xl" lang="pt-BR">
                {bairro.introducao}
              </p>
              <div class="mt-10">
                <VizinhosCarousel client:visible bairro={bairro} />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
