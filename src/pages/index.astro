---
import Layout from '../components/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer.astro';
import NeighborhoodHistory from '../components/NeighborhoodHistory.astro';
import ConhecendoVizinhos from '../components/ConhecendoVizinhos.astro';
import PlaceCarousel from '../components/PlaceCarousel';
import { getAllLugares } from '../lib/lugares';

const lugares = getAllLugares();
---

<Layout
  title="Ipiranga Pocket List — Guia do bairro"
  description="Guia curado de lugares do Ipiranga e entorno: comida, cultura, lazer, esporte e muito mais."
>
  <Header client:load />
  <main>
    <!-- Hero Swiss -->
    <section class="swiss-grid-bg relative border-b border-swiss-black px-4 py-12 sm:px-6 sm:py-20 md:px-8 md:py-24 lg:py-32">
      <div class="mx-auto grid max-w-7xl gap-8 sm:gap-12 lg:grid-cols-12 lg:items-end">
        <div class="lg:col-span-8">
          <span class="swiss-label">01 — Guia do bairro</span>
          <h1 class="mt-4 text-[clamp(2.25rem,10vw,5rem)] font-bold leading-[0.95] tracking-tight sm:mt-6 sm:text-7xl lg:text-8xl">
            IPIRANGA<br />
            <span class="text-swiss-red">POCKET</span><br />
            LIST
          </h1>
        </div>
        <div class="lg:col-span-4 lg:border-l lg:border-swiss-black lg:pl-8">
          <p class="text-sm leading-relaxed text-swiss-gray-600 sm:text-base md:text-lg">
            Lugares para comer, visitar e viver o bairro — curados para quem quer conhecer o Ipiranga de verdade.
          </p>
          <div class="mt-6 flex flex-col gap-3 sm:mt-8 sm:flex-row">
            <a href="#lugares" class="btn-swiss">Explorar lugares</a>
            <a href="#vizinhos" class="btn-swiss-outline">Ver vizinhos</a>
          </div>
          <p class="mt-6 font-mono text-xs text-swiss-gray-400 sm:mt-8">
            {lugares.length} endereços · Zona Sul · São Paulo
          </p>
        </div>
      </div>
    </section>

    <NeighborhoodHistory />

    <section id="lugares" class="px-4 py-12 sm:px-6 sm:py-20 md:px-8 md:py-24">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-6 border-b border-swiss-black pb-8 lg:grid-cols-12">
          <div class="lg:col-span-4">
            <span class="swiss-label">03 — Lugares</span>
            <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
              Todos os lugares
            </h2>
          </div>
          <div class="flex items-end lg:col-span-8">
            <p class="text-sm text-swiss-gray-600">
              {lugares.length} endereços no Ipiranga e entorno. Navegue pelo carrossel ou filtre por categoria.
            </p>
          </div>
        </div>
        <div class="mt-10">
          <PlaceCarousel client:load places={lugares} />
        </div>
      </div>
    </section>

    <ConhecendoVizinhos />
  </main>
  <Footer />
</Layout>
