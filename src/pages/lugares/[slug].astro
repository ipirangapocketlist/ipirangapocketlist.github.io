---
import Layout from '../../components/Layout.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer.astro';
import { getLugarBySlug, getAllSlugs } from '../../lib/lugares';
import { CATEGORIA_LABELS, getCategoriaColor } from '../../data/categorias';

export function getStaticPaths() {
  return getAllSlugs().map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const lugar = slug ? getLugarBySlug(slug) : undefined;

if (!lugar) {
  return Astro.redirect('/');
}

const precoLabel: Record<string, string> = {
  '$': 'Econômico',
  '$$': 'Moderado',
  '$$$': 'Premium',
  gratuito: 'Gratuito',
  variavel: 'Variável',
};

const descricaoParagrafos = lugar.descricao.split('\n\n');
---

<Layout
  title={`${lugar.nome} — Ipiranga Pocket List`}
  description={descricaoParagrafos[0]}
>
  <Header client:load />
  <main class="mx-auto max-w-3xl px-4 py-8 sm:px-6 sm:py-12 md:px-8 md:py-16">
    <nav aria-label="Breadcrumb" class="mb-8 border-b border-swiss-gray-200 pb-4 text-xs uppercase tracking-widest text-swiss-gray-600 sm:mb-10">
      <a href="/" class="hover:text-swiss-red">Início</a>
      <span class="mx-2">/</span>
      <span class="break-words text-swiss-black">{lugar.nome}</span>
    </nav>

    <header class="mb-8 sm:mb-10">
      <div class="mb-4 flex flex-wrap items-center gap-2">
        <span class={`swiss-label border px-2 py-1 ${getCategoriaColor(lugar.categoria)}`}>
          {CATEGORIA_LABELS[lugar.categoria]}
        </span>
        {
          lugar.entorno && (
            <span class="border-b-2 border-swiss-red pb-0.5 text-[10px] font-bold uppercase tracking-widest text-swiss-red">
              Entorno
            </span>
          )
        }
      </div>
      <h1 class="text-2xl font-bold leading-tight tracking-tight sm:text-4xl md:text-5xl">
        {lugar.nome}
      </h1>
      <p class="mt-3 text-xs font-medium uppercase tracking-wider text-swiss-gray-600">
        {lugar.bairro} — {lugar.endereco}
      </p>
    </header>

    <article class="space-y-4 border-l-2 border-swiss-black pl-4 sm:space-y-5 sm:pl-6">
      {
        descricaoParagrafos.map((p, i) => (
          <p class={i === 0 ? 'text-lg font-medium leading-relaxed' : 'text-sm leading-relaxed text-swiss-gray-600'}>
            {p}
          </p>
        ))
      }
    </article>

    {
      lugar.tags.length > 0 && (
        <div class="mt-8 flex flex-wrap gap-2">
          {lugar.tags.map((tag) => (
            <span class="border border-swiss-black px-2 py-1 text-[10px] font-semibold uppercase tracking-widest">
              #{tag}
            </span>
          ))}
        </div>
      )
    }

    <aside class="card-swiss mt-10 p-5 sm:mt-12 sm:p-8" aria-label="Informações práticas">
      <h2 class="text-xs font-bold uppercase tracking-[0.2em]">Informações</h2>
      <div class="swiss-rule-red mt-4"></div>

      <dl class="mt-6 grid gap-4 sm:grid-cols-2">
        <div>
          <dt class="swiss-label">Categoria</dt>
          <dd class="mt-1 font-medium">{CATEGORIA_LABELS[lugar.categoria]}</dd>
        </div>
        <div>
          <dt class="swiss-label">Preço</dt>
          <dd class="mt-1 font-medium">{precoLabel[lugar.preco] ?? lugar.preco}</dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="swiss-label">Horário</dt>
          <dd class="mt-1 text-sm">{lugar.horario}</dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="swiss-label">Endereço</dt>
          <dd class="mt-1 text-sm">{lugar.endereco}</dd>
        </div>
        {
          lugar.telefone && (
            <div class="sm:col-span-2">
              <dt class="swiss-label">Telefone</dt>
              <dd class="mt-1">
                <a href={`tel:${lugar.telefone.replace(/\D/g, '')}`} class="font-medium hover:text-swiss-red">
                  {lugar.telefone}
                </a>
              </dd>
            </div>
          )
        }
      </dl>

      <div class="mt-6 border-l-2 border-swiss-red pl-4">
        <p class="text-xs font-bold uppercase tracking-widest">Dica</p>
        <p class="mt-1 text-sm text-swiss-gray-600">{lugar.dica}</p>
      </div>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <a href={lugar.links.maps} target="_blank" rel="noopener noreferrer" class="btn-swiss">
          Como chegar
        </a>
        {
          lugar.site && (
            <a href={lugar.site} target="_blank" rel="noopener noreferrer" class="btn-swiss-outline">
              Site
            </a>
          )
        }
        {
          lugar.links.instagram && (
            <a href={lugar.links.instagram} target="_blank" rel="noopener noreferrer" class="btn-swiss-outline">
              Instagram
            </a>
          )
        }
      </div>
    </aside>

    <p class="mt-10">
      <a href="/#lugares" class="text-xs font-semibold uppercase tracking-widest hover:text-swiss-red">
        ← Voltar para lugares
      </a>
    </p>
  </main>
  <Footer />
</Layout>
